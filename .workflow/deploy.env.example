# gonghao-numbers GCP 部署設定範例
# 複製為 deploy.env 並填入實際值（勿 commit deploy.env）：
#   cp .workflow/deploy.env.example .workflow/deploy.env

# --- 必填 ---

# GCP 專案 ID
GCP_PROJECT_ID=

# Cloud Run 服務區域（例：asia-east1）
GCP_REGION=

# Cloud Run 服務名稱
SERVICE_NAME=gonghao-numbers

# Artifact Registry 區域（通常與 GCP_REGION 相同）
ARTIFACT_REGISTRY_LOCATION=asia-east1

# Artifact Registry Docker 儲存庫名稱（不存在時 deploy.sh 會自動建立）
ARTIFACT_REGISTRY_REPOSITORY=gonghao-numbers

# --- 選填 ---

# 映像標籤（預設：目前 git commit short SHA，無 git 時用 UTC 時間戳）
# IMAGE_TAG=latest

# 是否允許未驗證存取（公開 HTTP，預設 true）
CLOUD_RUN_ALLOW_UNAUTHENTICATED=true

# Cloud Run 資源與擴縮（留空則使用平台預設）
# CLOUD_RUN_CPU=1
# CLOUD_RUN_MEMORY=512Mi
# CLOUD_RUN_MIN_INSTANCES=0
# CLOUD_RUN_MAX_INSTANCES=10

# 非敏感環境變數（逗號分隔 KEY=VALUE）
# 例：啟用 OpenAI LLM（API key 請用 Secret Manager，見 DEPLOY.md）
# CLOUD_RUN_ENV_VARS=LLM_PROVIDER=openai,OPENAI_BASE_URL=https://api.openai.com/v1,OPENAI_MODEL=gpt-4o-mini

# Secret Manager 對應（逗號分隔 ENV_NAME=SECRET_NAME:VERSION）
# 例：OPENAI_API_KEY=openai-api-key:latest
# CLOUD_RUN_SECRETS=OPENAI_API_KEY=openai-api-key:latest
